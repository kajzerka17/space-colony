<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".UpgradeActivity">

    <ImageView
        android:id="@+id/backgroundUpgrade"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleX="1.25"
        android:scaleY="1.25"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/shop" />

    <TextView
        android:id="@+id/textUpgradeTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:fontFamily="@font/audiowide"
        android:text="Upgrades"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:shadowColor="#000000"
        android:shadowDx="1"
        android:shadowDy="1"
        android:shadowRadius="8"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/fragmentsBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="32dp"
        android:background="#66000000"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textUpgradeTitle">

        <TextView
            android:id="@+id/textFragmentsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/audiowide"
            android:text="Fragments: "
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:shadowColor="#000000"
            android:shadowRadius="8"
            android:shadowDx="1"
            android:shadowDy="1"/>

        <TextView
            android:id="@+id/textFragmentsValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/audiowide"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:shadowColor="#000000"
            android:shadowRadius="8"
            android:shadowDx="1"
            android:shadowDy="1"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"></LinearLayout>

    <ScrollView
        android:id="@+id/scrollView3"
        android:layout_width="0dp"
        android:layout_height="400dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/fragmentsBox">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="#66000000"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/audiowide"
                    android:text="Power Cell"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:shadowColor="#000000"
                    android:shadowRadius="8"
                    android:shadowDx="1"
                    android:shadowDy="1"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/audiowide"
                    android:text="Cost: 3 Fragments"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:shadowColor="#000000"
                    android:shadowRadius="8"
                    android:shadowDx="1"
                    android:shadowDy="1"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/audiowide"
                    android:text="+10 base Power per day"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:shadowColor="#000000"
                    android:shadowRadius="8"
                    android:shadowDx="1"
                    android:shadowDy="1"/>

                <Button
                    android:id="@+id/buttonPowerCell"
                    style="@style/Widget.AppCompat.Button.Colored"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/audiowide"
                    android:text="Buy"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="@color/mainButton" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="#66000000"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/audiowide"
                    android:text="Training Rig"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:shadowColor="#000000"
                    android:shadowRadius="8"
                    android:shadowDx="1"
                    android:shadowDy="1"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/audiowide"
                    android:text="Cost: 4 Fragments"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:shadowColor="#000000"
                    android:shadowRadius="8"
                    android:shadowDx="1"
                    android:shadowDy="1"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/audiowide"
                    android:text="Simulator grants more XP"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:shadowColor="#000000"
                    android:shadowRadius="8"
                    android:shadowDx="1"
                    android:shadowDy="1"/>

                <Button
                    android:id="@+id/buttonTrainingRig"
                    style="@style/Widget.AppCompat.Button.Colored"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/audiowide"
                    android:text="Buy"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="@color/mainButton" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="#66000000"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/audiowide"
                    android:text="Recruitment Post"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:shadowColor="#000000"
                    android:shadowRadius="8"
                    android:shadowDx="1"
                    android:shadowDy="1"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/audiowide"
                    android:text="Cost: 6 Fragments"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:shadowColor="#000000"
                    android:shadowRadius="8"
                    android:shadowDx="1"
                    android:shadowDy="1"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/audiowide"
                    android:text="Unlocks one extra recruit slot"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:shadowColor="#000000"
                    android:shadowRadius="8"
                    android:shadowDx="1"
                    android:shadowDy="1"/>

                <Button
                    android:id="@+id/buttonRecruitmentPost"
                    style="@style/Widget.AppCompat.Button.Colored"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/audiowide"
                    android:text="Buy"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="@color/mainButton" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#66000000"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/audiowide"
                    android:text="Command Center"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:shadowColor="#000000"
                    android:shadowRadius="8"
                    android:shadowDx="1"
                    android:shadowDy="1"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/audiowide"
                    android:text="Cost: 8 Fragments"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:shadowColor="#000000"
                    android:shadowRadius="8"
                    android:shadowDx="1"
                    android:shadowDy="1"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/audiowide"
                    android:text="Unlocks one extra squad size for missions"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:shadowColor="#000000"
                    android:shadowRadius="8"
                    android:shadowDx="1"
                    android:shadowDy="1"/>

                <Button
                    android:id="@+id/buttonCommandCenter"
                    style="@style/Widget.AppCompat.Button.Colored"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/audiowide"
                    android:text="Buy"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="@color/mainButton" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/backButton"
        style="@style/Widget.AppCompat.Button.Colored"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:fontFamily="@font/audiowide"
        android:scaleX="1.5"
        android:scaleY="1.5"
        android:text="go back"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/scrollView3"
        app:backgroundTint="@color/mainButton"/>

</androidx.constraintlayout.widget.ConstraintLayout>